generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id          String    @id @unique
  email       String    @unique
  name        String?
  sessionData Article[]
}

model Article {
  id         String   @id
  createdAt  DateTime @default(now())
  title      String
  orgArticle String
  sumArticle String

  userId  String
  user    User   @relation(fields: [userId], references: [id])
  quizzes Quiz[]
}

model Quiz {
  id           String  @id
  question     String
  answer       String
  refArticleId String
  refArticle   Article @relation(fields: [refArticleId], references: [id])
}
